# ============================================================
# ABAP Accelerator MCP Server - Azure Entra ID Configuration
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_BASE_URL=http://localhost:8000


# ------------------------------------------------------------
# Enterprise Mode
# ------------------------------------------------------------
ENABLE_ENTERPRISE_MODE=true
ENABLE_PRINCIPAL_PROPAGATION=false

# ------------------------------------------------------------
# OAuth - Microsoft Entra ID (Azure AD)
# Tenant: fb04c3d4-53a6-4c0a-b26e-55f336322657 / App: 128a32b7-358e-4f9d-915d-2dd7d7d34bbb
# ------------------------------------------------------------
ENABLE_OAUTH_FLOW=true

OAUTH_ISSUER=https://login.microsoftonline.com/fb04c3d4-53a6-4c0a-b26e-55f336322657/v2.0
OAUTH_AUTH_ENDPOINT=https://login.microsoftonline.com/fb04c3d4-53a6-4c0a-b26e-55f336322657/oauth2/v2.0/authorize
OAUTH_TOKEN_ENDPOINT=https://login.microsoftonline.com/fb04c3d4-53a6-4c0a-b26e-55f336322657/oauth2/v2.0/token

OAUTH_CLIENT_ID=128a32b7-358e-4f9d-915d-2dd7d7d34bbb
OAUTH_CLIENT_SECRET={azure-client-secret}
OAUTH_AUDIENCE=128a32b7-358e-4f9d-915d-2dd7d7d34bbb


# ------------------------------------------------------------
# SAP Connection
# ------------------------------------------------------------
DEFAULT_SAP_SYSTEM_ID=DEV
CREDENTIAL_PROVIDER=env

SAP_HOST=localhost
SAP_CLIENT=100
SAP_USERNAME=dummy
SAP_PASSWORD=dummy
SAP_LANGUAGE=EN
SAP_SECURE=false
SSL_VERIFY=false

# ------------------------------------------------------------
# AWS
# ------------------------------------------------------------
AWS_REGION=us-west-2
