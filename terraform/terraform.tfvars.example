# ============================================================================
# ABAP MCP Server - Terraform Configuration
# ============================================================================
# Environment: Dev (NonProd - Internal Only)
# Deployment: ECS Fargate + ALB + Route53 (multi-account)
# External: OAuth (Entra ID), CA certificates, SAP systems via Parameter Store
# ============================================================================

# ============================================================================
# AWS Accounts
# ============================================================================

region       = "us-west-2"
environment  = "Dev"
project_name = "abap-mcp-server"

# Application Account (ECS, ALB, Secrets Manager)
account_num = "064160142714"
aws_role    = "CloudAdmin"

# Route53 Account (DNS management)
account_num_r53 = "514712703977"
aws_r53_role    = "TFCBR53Role"

# ============================================================================
# Networking
# ============================================================================

vpc_id = "vpc-0f991a507e8e58aa1"

private_subnet_ids = [
  "subnet-009076f40b21b0adf", # us-west-2a
  "subnet-075d0438fa8ebac6a", # us-west-2b
  "subnet-0a22706e08d2a983f", # us-west-2c
]

allowed_cidr_blocks = ["0.0.0.0/0"]

# ============================================================================
# DNS
# ============================================================================

route53_hosted_zone_name = "nonprod.pge.com"
application_hostname     = "abap-mcp-server"
use_private_zone         = true

# ============================================================================
# Container
# ============================================================================

container_image  = "064160142714.dkr.ecr.us-west-2.amazonaws.com/abap-mcp-server:20260418193204"
container_cpu    = 512
container_memory = 1024
container_port   = 8000
desired_count    = 1

# ============================================================================
# Application
# ============================================================================

enable_enterprise_mode       = true
enable_principal_propagation = true
enable_oauth_flow            = false
credential_provider          = "aws_secrets"
ssl_verify                   = "true"

log_level                   = "INFO"
enable_http_request_logging = "false"

# ============================================================================
# Secrets (Managed Externally)
# ============================================================================

ca_secret_name              = "mcp/abap-mcp-server/ca-certificate"
oauth_secret_name           = "mcp/abap-mcp-server/oauth-credentials"
jwt_signing_key_secret_name = "mcp/abap-mcp-server/jwt-signing-key"

# ============================================================================
# SSM Parameters (Created via scripts/create-aws-parameters.sh)
# ============================================================================

sap_endpoints_parameter   = "/mcp/abap-mcp-server/sap-endpoints"
user_exceptions_parameter = "/mcp/abap-mcp-server/user-exceptions"

# ============================================================================
# OAuth (Microsoft Entra ID)
# ============================================================================

oauth_issuer         = "https://login.microsoftonline.com/fb04c3d4-53a6-4c0a-b26e-55f336322657/v2.0"
oauth_auth_endpoint  = "https://login.microsoftonline.com/fb04c3d4-53a6-4c0a-b26e-55f336322657/oauth2/v2.0/authorize"
oauth_token_endpoint = "https://login.microsoftonline.com/fb04c3d4-53a6-4c0a-b26e-55f336322657/oauth2/v2.0/token"
oauth_client_id      = "128a32b7-358e-4f9d-915d-2dd7d7d34bbb"
server_base_url      = "https://abap-mcp-server.nonprod.pge.com"

# ============================================================================
# Monitoring
# ============================================================================

enable_container_insights = true
log_retention_days        = 30

# ============================================================================
# Tags
# ============================================================================

tags = {
  Project            = "ABAP-MCP-Server"
  Environment        = "Dev"
  AppID              = "APP-3601"
  Order              = "70053108"
  Compliance         = "None"
  DataClassification = "Internal"
  CRIS               = "Low"
  Notify             = "avrg@pge.com_m7k3@pge.com_mq28@pge.com"
  Owner              = "avrg_m7k3_mq28"
  ManagedBy          = "Terraform"
  Application        = "MCP-Server"
}
