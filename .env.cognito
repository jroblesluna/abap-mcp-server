# ============================================================
# ABAP Accelerator MCP Server - AWS Cognito Configuration
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_BASE_URL=http://localhost:8000


# ------------------------------------------------------------
# Enterprise Mode
# ------------------------------------------------------------
ENABLE_ENTERPRISE_MODE=true
ENABLE_PRINCIPAL_PROPAGATION=false

# ------------------------------------------------------------
# OAuth - AWS Cognito (us-west-2)
# Pool: us-west-2_1oOII3FZT
# ------------------------------------------------------------
ENABLE_OAUTH_FLOW=true

OAUTH_ISSUER=https://cognito-idp.us-west-2.amazonaws.com/us-west-2_1oOII3FZT
OAUTH_AUTH_ENDPOINT=https://us-west-21ooii3fzt.auth.us-west-2.amazoncognito.com/oauth2/authorize
OAUTH_TOKEN_ENDPOINT=https://us-west-21ooii3fzt.auth.us-west-2.amazoncognito.com/oauth2/token

OAUTH_CLIENT_ID=4ccmf4o2t2l2o1mv61557bn6l7
OAUTH_CLIENT_SECRET={cognito-client-secret}
OAUTH_AUDIENCE=


# ------------------------------------------------------------
# SAP Connection
# ------------------------------------------------------------
DEFAULT_SAP_SYSTEM_ID=DEV
CREDENTIAL_PROVIDER=env

SAP_HOST=localhost
SAP_CLIENT=100
SAP_USERNAME=dummy
SAP_PASSWORD=dummy
SAP_LANGUAGE=EN
SAP_SECURE=false
SSL_VERIFY=false

# ------------------------------------------------------------
# AWS
# ------------------------------------------------------------
AWS_REGION=us-west-2
