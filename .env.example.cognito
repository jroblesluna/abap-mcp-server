# ============================================================
# ABAP Accelerator MCP Server - AWS Cognito Configuration
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_BASE_URL=http://localhost:8000


# ------------------------------------------------------------
# Enterprise Mode
# ------------------------------------------------------------
ENABLE_ENTERPRISE_MODE=true
ENABLE_PRINCIPAL_PROPAGATION=true

# ------------------------------------------------------------
# OAuth - AWS Cognito (us-west-2) - PG&E SSO
# Pool: abap-mcp-server-user-pool (us-west-2_JzZVWBh3o)
# Domain: pge-abap-mcp-dev
# ------------------------------------------------------------
ENABLE_OAUTH_FLOW=true

OAUTH_ISSUER=https://cognito-idp.us-west-2.amazonaws.com/us-west-2_JzZVWBh3o
OAUTH_AUTH_ENDPOINT=https://pge-abap-mcp-dev.auth.us-west-2.amazoncognito.com/oauth2/authorize
OAUTH_TOKEN_ENDPOINT=https://pge-abap-mcp-dev.auth.us-west-2.amazoncognito.com/oauth2/token

OAUTH_CLIENT_ID=43inhut2jbnsks1d7i75ckvcki
OAUTH_CLIENT_SECRET={client-secret}
OAUTH_AUDIENCE=


# ------------------------------------------------------------
# SAP Connection
# ------------------------------------------------------------
DEFAULT_SAP_SYSTEM_ID=DEV
CREDENTIAL_PROVIDER=env

SAP_HOST=localhost
SAP_CLIENT=100
SAP_USERNAME=dummy
SAP_PASSWORD=dummy
SAP_LANGUAGE=EN
SAP_SECURE=false
SSL_VERIFY=true

# ------------------------------------------------------------
# AWS
# ------------------------------------------------------------
AWS_REGION=us-west-2

# ------------------------------------------------------------
# Principal Propagation - CA Certificate
# ------------------------------------------------------------
CA_SECRET_NAME=mcp/abap-mcp-server/ca-certificate

# ------------------------------------------------------------
# Principal Propagation - SAP Endpoints (SSM Parameter Store)
# ------------------------------------------------------------
SAP_ENDPOINTS_PARAMETER=/abap-accelerator/sap-endpoints

# ------------------------------------------------------------
# JWT Signing Key (for testing purposes only)
# ------------------------------------------------------------
JWT_SIGNING_KEY=161cc2cd7a5127124115a52e756f32f2a2678f77bfdd7b8363d66ff9bdbb36b8